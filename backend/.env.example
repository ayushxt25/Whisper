APP_NAME=AI Voice Summarizer
APP_ENVIRONMENT=development
USE_MOCK_AI=true
DATABASE_URL=sqlite:///./whisper.db
PROCESSING_MODE=sync
REDIS_URL=redis://localhost:6379/0

GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-3.5-flash

GENERATED_DIR=generated
MAX_UPLOAD_SIZE_MB=25
ALLOWED_AUDIO_EXTENSIONS=.mp3,.wav,.webm,.m4a,.mp4,.ogg
ALLOWED_AUDIO_MIME_TYPES=audio/mpeg,audio/mp3,audio/wav,audio/x-wav,audio/webm,audio/mp4,audio/x-m4a,audio/m4a,audio/ogg

CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,https://your-whisper-app.vercel.app
CORS_ALLOW_CREDENTIALS=false
CORS_ALLOW_METHODS=GET,POST,OPTIONS
CORS_ALLOW_HEADERS=Content-Type,Authorization
